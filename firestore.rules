rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid;
    }

    match /tournaments/{tournamentId} {
      allow read: if request.auth != null;
      // Admin can do anything
      // Any authenticated user can join a draft tournament (update players + updatedAt only)
      allow write: if request.auth.token.email == 'jasmongu@gmail.com'
                   || (request.auth != null
                       && resource.data.status == 'draft'
                       && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players', 'updatedAt']));

      match /matches/{matchId} {
        allow read: if request.auth != null;
        allow write: if request.auth.token.email == 'jasmongu@gmail.com';
      }
    }

    match /standings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.email == 'jasmongu@gmail.com';
    }

    match /palmares/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.email == 'jasmongu@gmail.com';
    }
  }
}
